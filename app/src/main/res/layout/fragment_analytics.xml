<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analitik Real-Time"
            android:textColor="@color/navy"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Laporan Mingguan Detail -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengeluaran 7 Hari Terakhir"
                    android:textColor="@color/navy"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Chart with Axis Labels -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp">

                    <!-- Y-Axis Labels -->
                    <LinearLayout
                        android:id="@+id/y_axis"
                        android:layout_width="wrap_content"
                        android:layout_height="150dp"
                        android:orientation="vertical"
                        android:gravity="end"
                        android:paddingEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="1jt" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="500k" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="0" android:textSize="10sp"/>
                    </LinearLayout>

                    <!-- Bars Area -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_toEndOf="@id/y_axis"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_chart_grid">

                        <!-- Sun -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="16dp" android:layout_height="80dp" android:background="@color/expense"/>
                        </LinearLayout>
                        <!-- Mon -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="16dp" android:layout_height="40dp" android:background="@color/expense"/>
                        </LinearLayout>
                        <!-- Tue -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="16dp" android:layout_height="120dp" android:background="@color/expense"/>
                        </LinearLayout>
                        <!-- Wed (Today 29 Apr) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="16dp" android:layout_height="95dp" android:background="@color/navy"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- X-Axis Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/y_axis"
                        android:layout_toEndOf="@id/y_axis"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="26" android:gravity="center" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="27" android:gravity="center" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="28" android:gravity="center" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="29" android:gravity="center" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/navy"/>
                    </LinearLayout>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distribusi Kategori"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Makanan &amp; Minuman"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Rp 450.000 (45%)" android:textStyle="bold"/>
                    </RelativeLayout>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transportasi"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Rp 200.000 (20%)" android:textStyle="bold"/>
                    </RelativeLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>